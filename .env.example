# Cairn environment configuration
# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
CAIRN_DATA_DIR=./data

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
CAIRN_HOST=0.0.0.0
CAIRN_PORT=8000
CAIRN_RELOAD=true

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
CAIRN_SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# SSE stream
# ---------------------------------------------------------------------------
# CAIRN_STREAM_KEEPALIVE_SECONDS=15

# ---------------------------------------------------------------------------
# GitLab integration (Phase 3)
# ---------------------------------------------------------------------------
# Base URL of your GitLab instance as seen from inside the cairn-api container.
# Docker Compose: use the internal service name — nginx listens on port 80
#   inside the network (8080:80 is the host-side mapping only).
#   CAIRN_GITLAB_URL=http://gitlab
# External self-hosted: CAIRN_GITLAB_URL=http://gitlab.local
# Cloud:               CAIRN_GITLAB_URL=https://gitlab.com
CAIRN_GITLAB_URL=http://gitlab

# Personal access token or project access token with read_repository scope.
CAIRN_GITLAB_TOKEN=

# Numeric project ID (e.g. 42) or namespaced path (e.g. security-team/methodologies).
CAIRN_GITLAB_PROJECT_ID=

# Directory in the repo that contains methodology .yml files.
# Default 'methodologies' scans only the cybersecurity methodology directory.
# Set to '.' (repo root) to also sync sigma/ and playbooks/ in one pass —
# the webhook handler already skips Sigma validation for non-sigma/ paths.
# CAIRN_GITLAB_METHODOLOGY_DIR=methodologies
# CAIRN_GITLAB_METHODOLOGY_DIR=.   # Phase 4.2: include playbooks/{domain}/ dirs

# Secret token configured in GitLab project webhook settings.
# Leave empty to disable verification (not recommended in production).
CAIRN_GITLAB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# ChromaDB integration (Phase 3)
# ---------------------------------------------------------------------------
# Hostname of the ChromaDB HTTP server (Docker service name in Compose).
CAIRN_CHROMA_HOST=chromadb

# Port of the ChromaDB HTTP server (default 8000 inside the container).
CAIRN_CHROMA_PORT=8000

# ChromaDB collection name for methodology semantic search.
# CAIRN_CHROMA_COLLECTION=methodologies

# ---------------------------------------------------------------------------
# Quartz knowledge base (Phase 4)
# ---------------------------------------------------------------------------
# Path to the Quartz content directory where promoted notes are written.
CAIRN_QUARTZ_CONTENT_DIR=./quartz/content

# Path to the Quartz project root (contains quartz.config.ts, etc.).
CAIRN_QUARTZ_PROJECT_DIR=./quartz

# Command to rebuild the Quartz static site after promotion writes.
# Leave empty to skip automatic rebuild (useful during development).
CAIRN_QUARTZ_SYNC_CMD=

# Port for the KB web server (Quartz static site).
CAIRN_KB_PORT=8082

# ChromaDB collection name for promoted vault notes (separate from methodologies).
# CAIRN_VAULT_COLLECTION=vault-notes

# ---------------------------------------------------------------------------
# Corroboration detection (Phase 4)
# ---------------------------------------------------------------------------
# Minimum number of distinct agents that must mention the same entity within
# the time window to trigger an automatic promotion candidate.
# CAIRN_CORROBORATION_N=2

# Time window in hours within which corroboration is detected.
# CAIRN_CORROBORATION_WINDOW_HOURS=24

# Minimum confidence score for an agent self-nomination (promote: candidate)
# to create a promotion candidate without human intervention.
# CAIRN_PROMOTION_CONFIDENCE_THRESHOLD=0.7

# NLP optional features (Phase 4.5)
CAIRN_SPACY_ENABLED=false

