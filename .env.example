# Cairn environment configuration
# Copy to .env and fill in values

# Data directory for SQLite databases
CAIRN_DATA_DIR=./data

# API settings
CAIRN_HOST=0.0.0.0
CAIRN_PORT=8000
CAIRN_RELOAD=true

# Security
CAIRN_SECRET_KEY=change-me-in-production

# Agent API keys (comma-separated name:key pairs)
# CAIRN_AGENT_KEYS=osint-agent-01:key1,vuln-agent-01:key2
